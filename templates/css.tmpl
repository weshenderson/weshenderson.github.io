/* Reset + base */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  font-family: $font;
  background-color: $background;
  color: $font_color;
}

a {	
  color: inherit;
  font-family: inherit;
}

a:visited {
  color: $link;
  font-family: inherit;
}

/* Header & footer centered horizontally */
header,
footer {
  font-size: ${font_size_secondary}em;
  text-align: center;
  padding: 1rem;
}

/* Main content takes remaining space */
.content {
  flex: 1;
  display: flex;
  align-items: center;        /* vertical centering */
  justify-content: space-between;
  padding: 1rem;
}

/* Left (image) */
.left {
  flex: 1;
  display: flex;
  justify-content: center;    /* horizontal centering inside column */
  align-items: center;        /* vertical centering */
}

.left img {
  max-width: 100%;
  height: auto;
}

/* Right (link-tree) */
.right {
  flex: 1;
  font-size: ${font_size_primary}em;
  display: flex;
  justify-content: center;
  align-items: center;
}

.right p {
  text-align: center;
}
