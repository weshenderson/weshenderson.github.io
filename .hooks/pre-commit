#!/usr/bin/env bash

# Disabling PDF generation due to changes with Chrome headless; it is no longer
# a separate binary shipped with Chrome. Must explore alternatives, or finally adopt LaTex.

set -eo pipefail

INDEX='index.html'
INDEX_CSS='assets/css/main.css'
RESUME='resumes/resume.html'
PDF='resumes/resume.pdf'
JSON='resumes/resume.json'
BASE_PATH="$(git rev-parse --show-toplevel)"
FILE_CHECK=(configs/
            alea
            templates/
            assets)

if [ -f /wsl ]; then
    BIN='/mnt/c/Program Files/Google/Chrome/Application/chrome.exe'
else
    BIN='/usr/bin/google-chrome'
fi

function alea {
    for file in ${FILE_CHECK[@]}; do
        if git status --porcelain | grep -q ${file}; then
            pushd "${BASE_PATH}" &>/dev/null
                ./alea.py --index --resume --json
                git add ${INDEX}
                git add ${INDEX_CSS}
                git add ${RESUME}
                git add ${JSON}
            popd &>/dev/null
            break
        fi
    done
}

function create-pdf-resume {
    if git status --porcelain | grep -q "${RESUME}"; then
        pushd "${BASE_PATH}" &>/dev/null
            local TMP='resume_pdf.html'
            cp ${RESUME} ${TMP}
            sed -i 's@<h3><a id="pdf" href="resume.pdf">Download PDF</a></h3>@@g' ${TMP}
            echo "${BIN}" \
                --headless \
                --disable-gpu \
                --no-pdf-header-footer \
                --no-margins \
                --run-all-compositor-stages-before-draw \
                --print-to-pdf ${PDF} \
                ${TMP}
            rm -f ${TMP}
            git add ${PDF}
        popd &>/dev/null
    fi
}

function check-code {
    echo 'Linting code: pylint.'
    pylint $(git ls-files '*.py')
}

check-code
alea
#create-pdf-resume
